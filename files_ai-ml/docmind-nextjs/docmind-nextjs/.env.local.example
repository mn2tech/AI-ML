# Required — Claude answers questions
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — Claude model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — OpenAI text-embedding-3-small (falls back to TF-IDF if omitted)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional — Upstash Redis (via Vercel Integration) for public visit counter
# Auto-injected when you connect Upstash Redis in Vercel → Storage / Integrations
KV_REST_API_URL=
KV_REST_API_TOKEN=
