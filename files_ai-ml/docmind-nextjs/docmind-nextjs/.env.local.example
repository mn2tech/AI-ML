# Required — Claude answers questions
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — Claude model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — OpenAI text-embedding-3-small (falls back to TF-IDF if omitted)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional — Google Drive integration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Set to your live URL for OAuth redirects (e.g. https://docmind-rag-omega.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
